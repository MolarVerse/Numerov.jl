Manifest.toml

# Solver outputs written into a case directory during local runs
test/testsets/**/Numerov.out
test/testsets/**/timings.out
test/testsets/**/*eigen*.dat
test/testsets/**/frequencies*.dat
test/testsets/**/bandstructure.dat
examples/**/Numerov.out
examples/**/timings.out
examples/**/*eigen*.dat
examples/**/frequencies*.dat
examples/**/bandstructure.dat

# Files generated by invoking Julia with --code-coverage
*.jl.cov
*.jl.*.cov

# Files generated by invoking Julia with --track-allocation
*.jl.mem

# System-specific files generated by BinaryProvider/BinDeps
deps/deps.jl
deps/build.log
deps/downloads/
deps/usr/
deps/src/

# Build artifacts for documentation generated by Documenter
docs/build/
docs/site/

# Local environment configuration
.vscode/
